{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "helpers:pinGitHubActionDigests"],
  "schedule": ["before 9am every day"],
  "minimumReleaseAge": "7 days",
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "minimumReleaseAge": null,
    "schedule": ["at any time"]
  },
  "pre-commit": {
    "enabled": true
  },
  "mise": {
    "managerFilePatterns": ["/^home/dot_config/mise/config\\.toml$/"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/home/\\.chezmoiexternal\\.toml$/"],
      "matchStrings": [
        "url\\s*=\\s*\"https://raw\\.githubusercontent\\.com/(?<depName>[^/]+/[^/]+)/(?<currentDigest>[a-f0-9]{40})/[^\"]+\"\\s*#\\s*(?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "git-refs",
      "packageNameTemplate": "https://github.com/{{{depName}}}"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/home/dot_zsh_plugins\\.txt$/"],
      "matchStrings": [
        "(?<depName>[A-Za-z0-9._-]+/[A-Za-z0-9._-]+)\\s+[^\\n#]*?\\bpin:(?<currentDigest>[a-f0-9]{40})\\b[^\\n#]*?#\\s*release:(?<currentValue>v?\\d[\\w.-]*)"
      ],
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/home/dot_zsh_plugins\\.txt$/"],
      "matchStrings": [
        "(?<depName>[A-Za-z0-9._-]+/[A-Za-z0-9._-]+)\\s+[^\\n#]*?\\bpin:(?<currentDigest>[a-f0-9]{40})\\b[^\\n#]*?#\\s*tag:(?<currentValue>v?\\d[\\w.-]*)"
      ],
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/home/dot_zsh_plugins\\.txt$/"],
      "matchStrings": [
        "(?<depName>[A-Za-z0-9._-]+/[A-Za-z0-9._-]+)\\s+[^\\n#]*?\\bpin:(?<currentDigest>[a-f0-9]{40})\\b[^\\n#]*?#\\s*(?<currentValue>main|master|develop|trunk)\\b"
      ],
      "datasourceTemplate": "git-refs",
      "packageNameTemplate": "https://github.com/{{{depName}}}"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/home/dot_config/nvim/lua/config/lazy\\.lua$/"],
      "matchStrings": [
        "'(?<currentDigest>[a-f0-9]{40})' -- release:(?<currentValue>v?\\d[\\w.-]*)"
      ],
      "depNameTemplate": "folke/lazy.nvim",
      "packageNameTemplate": "folke/lazy.nvim",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/home/\\.chezmoiscripts/run_onchange_after_brew-bundle\\.sh\\.tmpl$/"
      ],
      "matchStrings": ["HOMEBREW_VERSION=\"(?<currentValue>[0-9.]+)\""],
      "depNameTemplate": "Homebrew/brew",
      "packageNameTemplate": "Homebrew/brew",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/home/\\.chezmoiscripts/run_onchange_after_yarn-berry-activate\\.sh\\.tmpl$/"
      ],
      "matchStrings": ["YARN_BERRY_VERSION=\"(?<currentValue>[0-9.]+)\""],
      "depNameTemplate": "@yarnpkg/cli",
      "packageNameTemplate": "yarnpkg/berry",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^@yarnpkg/cli/(?<version>.+)$"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["custom.regex"],
      "matchFileNames": ["home/dot_zsh_plugins.txt"],
      "addLabels": ["zsh-plugin"],
      "commitMessageTopic": "antidote plugin {{depName}}"
    },
    {
      "matchManagers": ["custom.regex"],
      "matchDepNames": ["Homebrew/brew"],
      "addLabels": ["homebrew"],
      "commitMessageTopic": "Homebrew installer (.pkg)",
      "description": "Renovate only bumps HOMEBREW_VERSION. The install script fetches the SHA-256 from GitHub's release-asset metadata at runtime and verifies the downloaded .pkg against it, then checks Apple's Developer ID signature and notarization independently."
    },
    {
      "matchManagers": ["custom.regex"],
      "matchDepNames": ["@yarnpkg/cli"],
      "addLabels": ["yarn-berry"],
      "commitMessageTopic": "yarn berry (corepack)",
      "description": "Renovate bumps YARN_BERRY_VERSION when a new @yarnpkg/cli release ships. The chezmoi run_onchange script then runs `corepack prepare yarn@<version> --activate` on next apply. Corepack verifies the downloaded artifact against its bundled integrity values."
    }
  ]
}
