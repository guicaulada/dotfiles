#!/bin/bash
# yarn berry pin hash: {{ "YARN_BERRY_VERSION=4.14.1" | sha256sum }}
set -euo pipefail

# Activate Yarn Berry as the default `yarn` shim via corepack. Without this, a fresh
# machine falls back to the EOL yarn 1.22.x classic launcher that ships with Node,
# which has no useful hardening surface and ignores ~/.yarnrc.yml entirely.
#
# Renovate (.github/renovate.json) bumps YARN_BERRY_VERSION when a new @yarnpkg/cli
# release ships. Corepack verifies the downloaded artifact against its bundled
# known-good integrity values; we don't need to ship our own hash.
#
# Per-project pins via `packageManager: "yarn@x.y.z"` still take precedence over the
# activated default — that's the design — but COREPACK_ENABLE_STRICT=1 in .zshenv
# refuses such pins unless the project also declares an integrity hash.

YARN_BERRY_VERSION="4.14.1"

if ! command -v corepack &>/dev/null; then
  echo "==> corepack not found; skipping yarn berry activation"
  exit 0
fi

current=$(yarn --version 2>/dev/null || echo "none")
if [[ "$current" == "$YARN_BERRY_VERSION" ]]; then
  echo "==> yarn berry already at $YARN_BERRY_VERSION"
  exit 0
fi

echo "==> Activating yarn berry $YARN_BERRY_VERSION via corepack (was: $current)..."
corepack prepare "yarn@$YARN_BERRY_VERSION" --activate
