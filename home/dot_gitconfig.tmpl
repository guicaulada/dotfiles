[user]
	name = {{ .name }}
	email = {{ .email }}
	signingkey = {{ template "onepasswordRead" .onepassword.ssh_key }}

[gpg]
	format = ssh

[gpg "ssh"]
	# Without this, signing works but `git verify-commit` cannot trust any key.
	allowedSignersFile = ~/.config/git/allowed_signers
{{- if eq .chezmoi.os "darwin" }}
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
{{- end }}

[commit]
	gpgsign = true

[init]
	defaultBranch = main

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[fetch]
	prune = true
	# Verify the integrity of every object received on fetch. Catches malformed or
	# tampered objects from a compromised remote before they enter your local repo.
	fsckObjects = true

[transfer]
	# Apply the same object-integrity checks to both fetch and receive paths.
	fsckObjects = true

[receive]
	# Reject pushes that introduce malformed or tampered objects.
	fsckObjects = true

[rerere]
	enabled = true
	autoupdate = true

[diff]
	algorithm = histogram

[merge]
	conflictstyle = zdiff3

[column]
	ui = auto

[branch]
	sort = -committerdate

[core]
	autocrlf = input
	pager = delta
	fsmonitor = true

[maintenance]
	auto = true

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	line-numbers = true
	side-by-side = false

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
{{- if .is_work }}

[includeIf "gitdir:~/Work/{{ .company }}/"]
	path = ~/Work/{{ .company }}/.gitconfig
{{- end }}
